# Full .gitignore for Flutter
# https://github.com/github/gitignore/blob/main/Dart.gitignore

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_scratch/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configurations and tasks for Visual Studio Code
# https://code.visualstudio.com/docs/editor/debugging#_launch-configurations
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android related
**/android/**/generated/
**/android/gen/
**/android/local.properties
**/android/out/
**/android/sdk.dir
*.jks
*.keystore
*.apk
*.aab

# iOS related
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Pods/
**/ios/Runner/GeneratedPluginRegistrant.[mh]
**/ios/Runner/Assets.xcassets/AppIcon.appiconset/*.png
**/DerivedData/
*.moved-aside
*.xccheckout
*.xcscmblueprint

# Web related
.web/

# Windows related
**/windows/flutter/ephemeral/
**/windows/flutter/generated/

# macOS related
**/macos/Flutter/ephemeral/
**/macos/Flutter/generated/

# Linux related
**/linux/flutter/ephemeral/
**/linux/flutter/generated/

# Coverage
coverage/

# .env file
.env
